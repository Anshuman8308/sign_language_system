NODE_ENV=development
PORT=5000

# MongoDB (Local or Atlas)
MONGODB_URI=mongodb://localhost:27017/digital-wallet
# Production: mongodb+srv://user:password@cluster.mongodb.net/digital-wallet?retryWrites=true&w=majority

# JWT Secrets (Generate strong random strings - min 32 chars)
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-characters-long-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters-long-here
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:5173
# Production: https://your-app.vercel.app

LOG_LEVEL=info
